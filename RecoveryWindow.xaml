<Window x:Class="FastImageDupe.RecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FastImageDupe"
        x:Name="RecoveryWindow_Title" Title="🔄 復原與資源回收管理" Height="650" Width="1100" WindowStartupLocation="CenterOwner" WindowState="Maximized" Background="#F3F4F6">
    
    <Window.Resources>
        <local:PathToImageConverter x:Key="PathToImageConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 頂部控制區：將「篩選」與「勾選」明確分離 -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1. 顯示篩選區 -->
            <GroupBox x:Name="Rec_GrpFilter" Grid.Column="0" Header="1. 顯示篩選 (不影響勾選狀態)" Padding="10,5" Margin="0,0,10,0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="Rec_LblStatus" Text="紀錄狀態: " FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#4B5563"/>
                        <CheckBox x:Name="Rec_ChkNormal" Content="正常紀錄" IsChecked="True" Click="Filter_Changed" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <CheckBox x:Name="Rec_ChkHidden" Content="已隱藏紀錄" Click="Filter_Changed" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="Rec_LblOpType" Text="操作類型: " FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#4B5563"/>
                        <CheckBox x:Name="Rec_ChkSmart" Content="智慧" IsChecked="True" Click="Filter_Changed" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <CheckBox x:Name="Rec_ChkGroup" Content="群組" IsChecked="True" Click="Filter_Changed" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <CheckBox x:Name="Rec_ChkPersonal" Content="個人" IsChecked="True" Click="Filter_Changed" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 2. 批次快速勾選區 -->
            <GroupBox x:Name="Rec_GrpBatch" Grid.Column="1" Header="2. 批次快速勾選 (針對顯示中的清單)" Padding="10,5" Background="White" BorderBrush="#D1D5DB" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="Rec_TxtBatchHint" Text="💡 點選下方清單某一列後，可使用智慧批次選取：" Foreground="#6B7280" Margin="0,5,0,8" FontSize="11" TextWrapping="Wrap"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button x:Name="Rec_BtnSelSmart" Content="🎯 勾選同屬【智慧】" Click="BtnSelectSameSmart_Click" Background="#EDE9FE" Foreground="#5B21B6" BorderThickness="0" Padding="10,4" Margin="0,0,10,5" Cursor="Hand"/>
                        <Button x:Name="Rec_BtnSelGroup" Content="🎯 勾選同屬【群組】" Click="BtnSelectSameGroup_Click" Background="#DBEAFE" Foreground="#1D4ED8" BorderThickness="0" Padding="10,4" Margin="0,0,10,5" Cursor="Hand"/>
                        <Button x:Name="Rec_BtnSelPersonal" Content="🎯 勾選同屬【個人】" Click="BtnSelectSamePersonal_Click" Background="#FCE7F3" Foreground="#BE185D" BorderThickness="0" Padding="10,4" Margin="0,0,0,5" Cursor="Hand"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="LogDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F9FAFB" Background="White" RowHeight="70" Margin="0,0,0,15" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="Rec_ColSelectAll" Content="全選" Click="ChkSelectAllVisible_Click" HorizontalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn x:Name="Rec_ColType" Header="類型" Binding="{Binding ActionType}" IsReadOnly="True" Width="60"/>
                <DataGridTextColumn x:Name="Rec_ColSmartId" Header="智慧ID" Binding="{Binding DisplaySmartId}" IsReadOnly="True" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="Rec_ColGroupId" Header="群組ID" Binding="{Binding DisplayGroupId}" IsReadOnly="True" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="Rec_ColPersonalId" Header="個人ID" Binding="{Binding DisplayPersonalId}" IsReadOnly="True" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn x:Name="Rec_ColTime" Header="時間" Binding="{Binding Timestamp, StringFormat=\{0:yyyy/MM/dd HH:mm:ss\}}" IsReadOnly="True" Width="140"/>
                <DataGridTextColumn x:Name="Rec_ColSource" Header="原始路徑 (還原目標)" Binding="{Binding SourcePath}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn x:Name="Rec_ColDest" Header="目前路徑 (隔離區)" Binding="{Binding DestPath}" IsReadOnly="True" Width="*"/>

                <DataGridTemplateColumn x:Name="Rec_ColPreview" Header="隔離區預覽" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Width="75" Height="65" Margin="2" Background="#E5E7EB">
                                <TextBlock Text="{Binding MissingFileText}" Foreground="#EF4444" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFileMissing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <Image Source="{Binding DestPath, Converter={StaticResource PathToImageConverter}}" Stretch="Uniform" ToolTip="{Binding PreviewTooltip}">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFileMissing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="Rec_MenuSmart" Header="🎯 將同屬【智慧】批次的紀錄打勾" Click="BtnSelectSameSmart_Click"/>
                    <MenuItem x:Name="Rec_MenuGroup" Header="🎯 將同屬【群組】批次的紀錄打勾" Click="BtnSelectSameGroup_Click"/>
                    <MenuItem x:Name="Rec_MenuPersonal" Header="🎯 將同屬【個人】批次的紀錄打勾" Click="BtnSelectSamePersonal_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- 💡 根據 UX 原則重新排序的按鈕區 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            
            <!-- [系統維護區] 針對全域，且不依賴打勾狀態，放最左邊並加上大間距 -->
            <Button x:Name="Rec_BtnClearMissing" Content="🧹 清除失效(缺檔)紀錄" Click="BtnRemoveMissing_Click" Background="#F59E0B" Foreground="White" Padding="15,10" FontWeight="Bold" Margin="0,0,30,0" Cursor="Hand"/>
            
            <!-- [清單顯示區] 針對打勾項目進行視覺管理，放中間並與右側操作區加上大間距 -->
            <Button x:Name="Rec_BtnHide" Content="👁️ 隱藏打勾" Click="BtnHide_Click" Background="#6B7280" Foreground="White" Padding="15,10" FontWeight="Bold" Margin="0,0,5,0" Cursor="Hand"/>
            <Button x:Name="Rec_BtnUnhide" Content="👁️ 解除隱藏" Click="BtnUnhide_Click" Background="#9CA3AF" Foreground="White" Padding="15,10" FontWeight="Bold" Margin="0,0,30,0" Cursor="Hand"/>
            
            <!-- [實體檔案操作區] 針對打勾項目進行實體更動 -->
            <!-- 負面/破壞性操作 (資源回收) 放左側，避免誤觸 -->
            <Button x:Name="Rec_BtnRecycle" Content="🗑️ 徹底丟入系統資源回收桶" Click="BtnRecycle_Click" Background="#EF4444" Foreground="White" Padding="15,10" FontWeight="Bold" Margin="0,0,15,0" Cursor="Hand"/>
            <!-- 正面/主要操作 (復原) 放最右側，符合心理預期動線 -->
            <Button x:Name="Rec_BtnRecover" Content="🔄 復原打勾至原路徑" Click="BtnRecover_Click" Background="#3B82F6" Foreground="White" Padding="15,10" FontWeight="Bold" Cursor="Hand"/>
            
        </StackPanel>
    </Grid>
</Window>